# Copia este archivo a .env y rellena los valores
# En Railway: pega estas variables en Settings → Variables

# Webhook al que el bot reenvía mensajes entrantes de WhatsApp
HABITARE_WEBHOOK_URL=https://habitare.lat/app/whatsapp_webhook.php

# Secret compartido con Habitare (cadena aleatoria larga)
# Genera una así (ejemplo): openssl rand -hex 32
SHARED_SECRET=REEMPLAZA-ESTO-CON-UNA-CADENA-ALEATORIA-LARGA

# Puerto HTTP — Railway lo asigna automáticamente (dejar sin cambiar)
PORT=3000

# Dónde guardar la sesión de WhatsApp (si reinicia container sin esto, tendrías que re-escanear QR)
# En Railway: monta un Volume persistente en /data y apunta aquí
SESSION_PATH=/data/wwebjs_auth
